#!/usr/bin/env node
/**
 * frinus-cred — by-reference credential resolver for the Frinus platform.
 *
 * SECURITY MODEL ("by reference, never by value")
 * ------------------------------------------------
 * The agent NEVER holds a secret as a literal. It references a credential BY
 * NAME (its vault ref). The secret value is resolved out of band — fetched from
 * the Control Plane vault, kept only in this process's memory, and written ONLY
 * to stdout, at the instant of execution. Nothing is materialized to disk.
 *
 * Intended usage is exclusively via shell expansion / process substitution, so
 * the value flows directly into the consuming process and is never rendered as
 * part of a command string on screen:
 *
 *     export MYSQL_PWD="$(frinus-cred mysql_x password)"
 *     mysql --defaults-extra-file=<(frinus-cred mysql_x --as=mysql-cnf) -e 'SELECT 1'
 *     PGPASSFILE=<(frinus-cred pg_x --as=pgpass) psql -c 'SELECT 1'
 *
 * HARD SAFETY GUARD: if stdout is a TTY (isatty), this tool REFUSES and exits
 * non-zero. That makes it structurally impossible to print a secret to the
 * terminal even by accident — `frinus-cred ref password` alone errors out; you
 * MUST capture it via $(...) or <(...).
 *
 * AUTH (reuses EXACTLY the same contract as the MCP cpClient credential_get):
 *   - URL:    $FRINUS_CP_URL            (default https://frinus-api.rdxsec.com.br)
 *   - APIKey: $FRINUS_API_KEY  (fallback $FRINUS_MEMORY_API_KEY)
 *             sent as the `X-API-Key` header — same as mcp/src/client/cp-client.ts
 *   - GET /api/v1/credentials/<ref>     (same endpoint the MCP tool calls)
 * The API key already scopes the tenant on the server side, so no X-Tenant-ID
 * is required for a single-tenant API key.
 *
 * If those env vars are not present in the shell, they are loaded from a 0600
 * config file at $FRINUS_CRED_CONFIG or ~/.frinus/cred.env (simple KEY=VALUE
 * lines, `export ` prefix tolerated). The file must be chmod 600 / owner-only.
 *
 * No external dependencies — uses only Node built-ins so it runs anywhere node
 * does, independent of the MCP server's node_modules.
 */

import https from "node:https";
import http from "node:http";
import fs from "node:fs";
import os from "node:os";
import path from "node:path";
import { URL } from "node:url";

const PROG = "frinus-cred";

function die(msg, code = 1) {
  process.stderr.write(`${PROG}: ${msg}\n`);
  process.exit(code);
}

function usage(code = 2) {
  process.stderr.write(
    `Usage: ${PROG} <ref> [<field>] [--as=raw|env|mysql-cnf|pgpass]\n\n` +
      `Resolves a vault credential BY REFERENCE and writes it to stdout ONLY.\n` +
      `Refuses to run when stdout is a terminal — capture it via $(...) or <(...).\n\n` +
      `  <ref>            credential reference (e.g. mysql_centerpag)\n` +
      `  <field>          single field to emit (default for --as=raw); e.g. password\n` +
      `  --as=raw         (default) emit the value of <field> (or the whole JSON if no field)\n` +
      `  --as=env         emit shell 'export VAR=...' lines for every scalar field\n` +
      `  --as=mysql-cnf   emit a [client] block for: mysql --defaults-extra-file=<(...)\n` +
      `  --as=pgpass      emit host:port:db:user:password for: PGPASSFILE=<(...)\n\n` +
      `Examples:\n` +
      `  export MYSQL_PWD="$(${PROG} mysql_x password)"\n` +
      `  mysql --defaults-extra-file=<(${PROG} mysql_x --as=mysql-cnf) -e 'SELECT 1'\n` +
      `  PGPASSFILE=<(${PROG} pg_x --as=pgpass) psql -c 'SELECT 1'\n`,
  );
  process.exit(code);
}

// ---------------------------------------------------------------------------
// HARD SAFETY GUARD — refuse to print a secret to a terminal.
// Done first, before any network/credential work, so a stray invocation never
// even contacts the vault.
// ---------------------------------------------------------------------------
if (process.stdout.isTTY) {
  die(
    "refusing to print secret to a terminal; capture it with $(...) or <(...) " +
      "(e.g. export MYSQL_PWD=\"$(" + PROG + " <ref> password)\").",
    3,
  );
}

// ---------------------------------------------------------------------------
// Arg parsing
// ---------------------------------------------------------------------------
const argv = process.argv.slice(2);
if (argv.length === 0 || argv.includes("-h") || argv.includes("--help")) usage();

let ref;
let field;
let format = "raw";
for (const a of argv) {
  if (a.startsWith("--as=")) {
    format = a.slice("--as=".length).trim();
  } else if (a.startsWith("--")) {
    die(`unknown option '${a}'`, 2);
  } else if (ref === undefined) {
    ref = a;
  } else if (field === undefined) {
    field = a;
  } else {
    die(`unexpected argument '${a}'`, 2);
  }
}
if (!ref) usage();

const VALID_FORMATS = new Set(["raw", "env", "mysql-cnf", "pgpass"]);
if (!VALID_FORMATS.has(format)) {
  die(`invalid --as='${format}'; expected one of: raw, env, mysql-cnf, pgpass`, 2);
}

// ---------------------------------------------------------------------------
// Config resolution: env first, then a 0600 config file fallback.
// ---------------------------------------------------------------------------
function loadConfigFile() {
  const candidate =
    process.env.FRINUS_CRED_CONFIG ||
    path.join(os.homedir(), ".frinus", "cred.env");
  let st;
  try {
    st = fs.statSync(candidate);
  } catch {
    return {};
  }
  // Refuse group/other-readable config (must be 0600-ish, owner-only).
  if (process.platform !== "win32" && (st.mode & 0o077) !== 0) {
    die(
      `config file ${candidate} is too permissive (mode ${(st.mode & 0o777).toString(8)}); ` +
        `run: chmod 600 ${candidate}`,
    );
  }
  const out = {};
  for (let line of fs.readFileSync(candidate, "utf8").split(/\r?\n/)) {
    line = line.trim();
    if (!line || line.startsWith("#")) continue;
    if (line.startsWith("export ")) line = line.slice("export ".length);
    const eq = line.indexOf("=");
    if (eq === -1) continue;
    const k = line.slice(0, eq).trim();
    let v = line.slice(eq + 1).trim();
    if (
      (v.startsWith('"') && v.endsWith('"')) ||
      (v.startsWith("'") && v.endsWith("'"))
    ) {
      v = v.slice(1, -1);
    }
    out[k] = v;
  }
  return out;
}

const fileCfg = loadConfigFile();
function cfg(name) {
  return process.env[name] || fileCfg[name];
}

const cpUrl = (cfg("FRINUS_CP_URL") || "https://frinus-api.rdxsec.com.br").replace(/\/+$/, "");
const apiKey = cfg("FRINUS_API_KEY") || cfg("FRINUS_MEMORY_API_KEY");
if (!apiKey) {
  die(
    "no API key found. Set FRINUS_API_KEY in the environment or in a 0600 " +
      `config file (${process.env.FRINUS_CRED_CONFIG || "~/.frinus/cred.env"}).`,
  );
}

// ---------------------------------------------------------------------------
// Fetch the credential (same endpoint + header as the MCP cpClient).
// ---------------------------------------------------------------------------
function fetchCredential() {
  return new Promise((resolve, reject) => {
    let u;
    try {
      u = new URL(`${cpUrl}/api/v1/credentials/${encodeURIComponent(ref)}`);
    } catch (e) {
      return reject(new Error(`invalid FRINUS_CP_URL '${cpUrl}': ${e.message}`));
    }
    const lib = u.protocol === "http:" ? http : https;
    const req = lib.request(
      u,
      {
        method: "GET",
        headers: { "X-API-Key": apiKey, Accept: "application/json" },
        timeout: 30000,
      },
      (res) => {
        let body = "";
        res.setEncoding("utf8");
        res.on("data", (c) => (body += c));
        res.on("end", () => {
          const status = res.statusCode || 0;
          if (status === 404) return reject({ http: 404 });
          if (status === 401 || status === 403) return reject({ http: status });
          if (status < 200 || status >= 300) {
            return reject(new Error(`Control Plane returned HTTP ${status}`));
          }
          try {
            resolve(JSON.parse(body));
          } catch {
            reject(new Error("invalid JSON response from Control Plane"));
          }
        });
      },
    );
    req.on("timeout", () => req.destroy(new Error("request timed out")));
    req.on("error", (e) => reject(new Error(`request failed: ${e.message}`)));
    req.end();
  });
}

// ---------------------------------------------------------------------------
// Output formatting (stdout only, never disk).
// ---------------------------------------------------------------------------
function isScalar(v) {
  return v !== null && v !== undefined && typeof v !== "object";
}

function pick(data, ...keys) {
  for (const k of keys) if (isScalar(data[k])) return String(data[k]);
  return undefined;
}

function findPassword(data) {
  const re = /pass(word|wd)?|secret|token|api[_-]?key|private[_-]?key/i;
  const k = Object.keys(data).find((key) => re.test(key) && isScalar(data[key]));
  return k ? String(data[k]) : undefined;
}

function shSingleQuote(s) {
  // Safe single-quote for shell: ' -> '\''
  return `'${String(s).replace(/'/g, "'\\''")}'`;
}

function emit(text) {
  // No trailing-newline coercion games: write exactly, add one newline for line
  // formats. For raw we still add a newline (mirrors $(...) which strips it).
  process.stdout.write(text.endsWith("\n") ? text : text + "\n");
}

(async () => {
  let data;
  try {
    data = (await fetchCredential()) || {};
  } catch (e) {
    if (e && e.http === 404) die(`no credential found for ref '${ref}'`, 4);
    if (e && (e.http === 401 || e.http === 403)) {
      die(`authentication/authorization failed (HTTP ${e.http}); check FRINUS_API_KEY`, 5);
    }
    die(e && e.message ? e.message : String(e));
    return;
  }
  if (typeof data !== "object" || Array.isArray(data)) {
    die("unexpected credential payload (not an object)");
  }

  if (format === "raw") {
    if (field) {
      if (!(field in data)) die(`credential '${ref}' has no field '${field}'`, 6);
      if (!isScalar(data[field])) die(`field '${field}' is not a scalar value`, 6);
      emit(String(data[field]));
    } else {
      // No field: whole credential as compact JSON (e.g. for jq downstream).
      emit(JSON.stringify(data));
    }
    return;
  }

  if (format === "env") {
    const lines = [];
    for (const [k, v] of Object.entries(data)) {
      if (!isScalar(v)) continue;
      const name = k.toUpperCase().replace(/[^A-Z0-9_]/g, "_");
      lines.push(`export ${name}=${shSingleQuote(v)}`);
    }
    if (lines.length === 0) die(`credential '${ref}' has no scalar fields`, 6);
    emit(lines.join("\n"));
    return;
  }

  if (format === "mysql-cnf") {
    const user = pick(data, "user", "username");
    const pw = findPassword(data);
    if (!user || pw === undefined) {
      die(`credential '${ref}' is missing user/password for mysql-cnf`, 6);
    }
    const host = pick(data, "host", "hostname");
    const port = pick(data, "port");
    const database = pick(data, "database", "db", "dbname");
    const out = ["[client]"];
    if (host) out.push(`host=${host}`);
    if (port) out.push(`port=${port}`);
    out.push(`user=${user}`);
    out.push(`password=${pw}`);
    if (database) out.push(`database=${database}`);
    emit(out.join("\n"));
    return;
  }

  if (format === "pgpass") {
    const user = pick(data, "user", "username");
    const pw = findPassword(data);
    if (!user || pw === undefined) {
      die(`credential '${ref}' is missing user/password for pgpass`, 6);
    }
    const host = pick(data, "host", "hostname") || "*";
    const port = pick(data, "port") || "*";
    const database = pick(data, "database", "db", "dbname") || "*";
    // .pgpass escapes ':' and '\' with a backslash.
    const esc = (s) => String(s).replace(/([:\\])/g, "\\$1");
    emit(`${esc(host)}:${esc(port)}:${esc(database)}:${esc(user)}:${esc(pw)}`);
    return;
  }
})();
